# AarogyaVani Environment Configuration
# Rename this file to .env.local and fill in your keys.

# 1. Native Google Gemini API Key (Primary, Fastest)
# Get yours at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 2. OpenRouter API Key (Fallback for other models like Llama/Qwen)
# Get yours at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# 3. Development Port
PORT=3000
