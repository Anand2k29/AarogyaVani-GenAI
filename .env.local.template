# AarogyaVani Environment Configuration
# Rename this file to .env.local and fill in your keys.

# 1. OpenRouter API Key (Llama 3.2 Vision / Llama 3.1 8B)
# Get yours at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# 2. Groq API Key (Cloud fallback)
# Get yours at: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# 3. Development Port
PORT=3000
